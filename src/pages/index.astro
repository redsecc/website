---
import BaseLayout from '../layouts/BaseLayout.astro';
import Logo from '../components/Logo.astro';
import { Code } from 'astro-expressive-code/components';
import { withBase } from '../lib/base';
import { SITE } from '../lib/site';

const LEARN = 'https://learn.redsec.cc';

// Marketing teasers — these link out to the learning platform; the actual
// learning materials live on learn.redsec.cc, not here.
const offerings = [
  {
    title: 'Paths',
    blurb: 'Structured tracks that take you from enumeration to exploitation, in order.',
    href: `${LEARN}/paths`,
  },
  {
    title: 'Labs',
    blurb: 'Guided challenges you run yourself, locally, on targets you own.',
    href: `${LEARN}/labs`,
  },
  {
    title: 'Reference',
    blurb: "Fast cheatsheets for when you're mid-engagement and just need the command.",
    href: `${LEARN}/reference`,
  },
];
---

<BaseLayout>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Free · open · no account</span>
        <h1 class="hero-title">
          Learn to <span class="accent">red team</span>.
        </h1>
        <p class="lead">
          RedSec is a free, open learning center for offensive security. No
          signup, no login, no tracking — start with the techniques the moment
          you land.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={LEARN}>Start learning →</a>
          <a class="btn" href={withBase('/about')}>What is RedSec?</a>
        </div>
        <p class="hero-note mono">No cookies. No analytics. No third-party requests.</p>
      </div>

      <!-- One angular accent per view: the chamfered terminal -->
      <div class="hero-accent">
        <div class="hero-mark">
          <Logo size={48} />
        </div>
        <Code
          code={`$ redsec --start\n[+] free · open · no account needed\n[>] launching platform → learn.redsec.cc`}
          lang="bash"
          frame="terminal"
          title="redsec"
        />
      </div>
    </div>
  </section>

  <!-- What you'll find -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>What you'll find</h2>
        <a class="mono section-link" href={LEARN}>Open the platform →</a>
      </div>
      <div class="grid grid-3">
        {
          offerings.map((o) => (
            <a class="offer-card" href={o.href}>
              <h3 class="offer-title">{o.title}</h3>
              <p class="offer-blurb">{o.blurb}</p>
              <span class="offer-go mono" aria-hidden="true">learn.redsec.cc →</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- What is red teaming -->
  <section class="section blurb-section">
    <div class="container blurb">
      <span class="eyebrow">What is red teaming?</span>
      <p>
        Red teaming is offensive security: thinking and acting like an adversary
        to find the weaknesses in a system before a real attacker does. You
        enumerate, you probe trust boundaries, and you chain small flaws into
        real impact — then you document it so defenders can fix it.
      </p>
      <p>
        Everything here is built for <strong>authorized testing and
        education</strong>. The techniques are real; use them only on systems
        you own or have explicit permission to test.
      </p>
    </div>
  </section>

  <!-- Community -->
  <section class="section community">
    <div class="container community-inner">
      <div>
        <h2>Built in the open</h2>
        <p class="lead">
          RedSec is free and open source. Come contribute lessons, file issues,
          or just hang out.
        </p>
      </div>
      <div class="community-actions">
        <a class="btn" href={SITE.social.github} target="_blank" rel="noopener noreferrer">GitHub ↗</a>
        <a class="btn" href={SITE.social.discord} target="_blank" rel="noopener noreferrer">Discord ↗</a>
        <a class="btn btn-primary" href={LEARN}>Start learning →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: var(--space-24) var(--space-16);
    border-bottom: var(--hairline);
  }
  .hero-grid {
    display: grid;
    gap: var(--space-12);
    align-items: center;
  }
  @media (min-width: 920px) {
    .hero-grid {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }
  .hero-title {
    font-size: clamp(2.5rem, 7vw, 4rem);
    margin-bottom: var(--space-6);
  }
  .hero-title .accent {
    color: var(--red);
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }
  .hero-note {
    margin-top: var(--space-4);
    color: var(--text-muted);
    font-size: 0.75rem;
  }

  .hero-accent {
    position: relative;
    background: var(--surface);
    border: var(--hairline);
    border-radius: var(--radius);
    clip-path: var(--chamfer);
    padding: var(--space-6);
  }
  .hero-mark {
    margin-bottom: var(--space-4);
  }
  .hero-accent :global(.expressive-code) {
    margin: 0;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-8);
    gap: var(--space-4);
  }
  .section-head h2 {
    margin: 0;
  }
  .section-link {
    color: var(--text-secondary);
    font-size: 0.85rem;
    white-space: nowrap;
  }
  .section-link:hover {
    color: var(--red-hover);
  }

  .offer-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--surface);
    border: var(--hairline);
    border-radius: var(--radius);
    padding: var(--space-6);
    color: var(--text);
    height: 100%;
    transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }
  .offer-card:hover {
    background: var(--elevated);
    border-color: var(--text-muted);
    text-decoration: none;
    transform: translateY(-2px);
  }
  .offer-title {
    margin: 0;
    font-size: 1.2rem;
  }
  .offer-blurb {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
  .offer-go {
    margin-top: auto;
    padding-top: var(--space-4);
    border-top: var(--hairline);
    color: var(--text-secondary);
    font-size: 0.8rem;
  }
  .offer-card:hover .offer-go {
    color: var(--red-hover);
  }

  .blurb-section {
    border-top: var(--hairline);
  }
  .blurb {
    max-width: var(--maxw-prose);
  }

  .community {
    border-top: var(--hairline);
  }
  .community-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
  }
  .community-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
</style>
