---
import Logo from './Logo.astro';
import { withBase } from '../lib/base';
import { SITE } from '../lib/site';

const nav = [
  { label: 'About', href: withBase('/about') },
  { label: 'Learn', href: 'https://learn.redsec.cc', external: true },
];

const social = [
  { label: 'GitHub', href: SITE.social.github, icon: 'github' },
  { label: 'Discord', href: SITE.social.discord, icon: 'discord' },
];

// Mark the active section (first path segment after the base).
const path = Astro.url.pathname.replace(/\/+$/, '');
const isActive = (href: string) => {
  const seg = href.replace(/\/+$/, '');
  return path === seg || path.startsWith(seg + '/');
};
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={withBase('/')} aria-label="RedSec home">
      <Logo size={34} />
      <span class="wordmark">RedSec</span>
    </a>

    <mobile-nav>
      <button
        class="nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="primary-nav"
        aria-label="Open menu"
      >
        <span class="nav-toggle-bars" aria-hidden="true"></span>
      </button>

      <nav id="primary-nav" class="primary-nav" aria-label="Primary">
        <ul>
          {
            nav.map((item) =>
              item.external ? (
                <li>
                  <a
                    href={item.href}
                    class="nav-link"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {item.label} ↗
                  </a>
                </li>
              ) : (
                <li>
                  <a
                    href={item.href}
                    class:list={['nav-link', { active: isActive(item.href) }]}
                    aria-current={isActive(item.href) ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              )
            )
          }
          <li class="nav-social">
            {
              social.map((s) => (
                <a
                  class="social-link"
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={s.label}
                  title={s.label}
                >
                  {s.icon === 'github' && (
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor">
                      <path d="M12 .5C5.37.5 0 5.78 0 12.29c0 5.2 3.44 9.6 8.21 11.16.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.04-3.34.72-4.04-1.6-4.04-1.6-.55-1.38-1.34-1.75-1.34-1.75-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.22 1.84 1.22 1.07 1.8 2.81 1.28 3.5.98.11-.77.42-1.28.76-1.58-2.67-.3-5.47-1.31-5.47-5.84 0-1.29.47-2.34 1.24-3.17-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.21.96-.26 1.98-.39 3-.4 1.02 0 2.04.14 3 .4 2.28-1.53 3.29-1.21 3.29-1.21.66 1.66.24 2.88.12 3.18.77.83 1.23 1.88 1.23 3.17 0 4.54-2.81 5.54-5.49 5.83.43.36.81 1.09.81 2.2 0 1.59-.01 2.87-.01 3.26 0 .32.21.7.82.58A12.01 12.01 0 0 0 24 12.29C24 5.78 18.63.5 12 .5z" />
                    </svg>
                  )}
                  {s.icon === 'discord' && (
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor">
                      <path d="M20.317 4.369a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.6 12.6 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.74 19.74 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.1 13.1 0 0 1-1.872-.892.077.077 0 0 1-.008-.128c.126-.094.252-.192.372-.291a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.009c.12.099.246.198.373.292a.077.077 0 0 1-.006.127 12.3 12.3 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.84 19.84 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.331c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" />
                    </svg>
                  )}
                </a>
              ))
            }
          </li>
        </ul>
      </nav>
    </mobile-nav>
  </div>
</header>

<script>
  // Small island: toggle the mobile menu. No framework, just a custom element.
  class MobileNav extends HTMLElement {
    connectedCallback() {
      const btn = this.querySelector<HTMLButtonElement>('.nav-toggle');
      const nav = this.querySelector<HTMLElement>('#primary-nav');
      if (!btn || !nav) return;

      const close = () => {
        this.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
        btn.setAttribute('aria-label', 'Open menu');
      };
      const open = () => {
        this.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
        btn.setAttribute('aria-label', 'Close menu');
      };

      btn.addEventListener('click', () => {
        this.classList.contains('open') ? close() : open();
      });

      // Close on navigation / Escape / resize to desktop.
      nav.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('a')) close();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
      window.addEventListener('resize', () => {
        if (window.innerWidth > 720) close();
      });
    }
  }
  if (!customElements.get('mobile-nav')) {
    customElements.define('mobile-nav', MobileNav);
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--surface) 92%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: var(--hairline);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text);
    font-weight: 500;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }
  .brand:hover {
    text-decoration: none;
  }
  .wordmark {
    line-height: 1;
  }

  .primary-nav ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0;
    padding: 0;
  }
  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-secondary);
    padding: 0.45rem 0.7rem;
    border-radius: var(--radius);
    border: 1px solid transparent;
    display: inline-block;
  }
  .nav-link:hover {
    color: var(--text);
    background: var(--elevated);
    text-decoration: none;
  }
  .nav-link.active {
    color: var(--text);
    /* single-sided accent → square that edge */
    border-radius: var(--radius) var(--radius) 0 0;
    border-bottom: 2px solid var(--red);
  }

  .nav-social {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    margin-left: var(--space-2);
    padding-left: var(--space-3);
    border-left: var(--hairline);
  }
  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius);
    color: var(--text-secondary);
  }
  .social-link:hover {
    color: var(--text);
    background: var(--elevated);
  }

  .nav-toggle {
    display: none;
    width: 2.5rem;
    height: 2.5rem;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: var(--line);
    border-radius: var(--radius);
    cursor: pointer;
  }
  .nav-toggle-bars,
  .nav-toggle-bars::before,
  .nav-toggle-bars::after {
    content: '';
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--text);
    transition: transform 0.15s ease, opacity 0.15s ease;
  }
  .nav-toggle-bars {
    position: relative;
  }
  .nav-toggle-bars::before {
    position: absolute;
    top: -6px;
  }
  .nav-toggle-bars::after {
    position: absolute;
    top: 6px;
  }

  @media (max-width: 720px) {
    .nav-toggle {
      display: inline-flex;
    }
    .primary-nav {
      position: absolute;
      top: 4rem;
      left: 0;
      right: 0;
      background: var(--surface);
      border-bottom: var(--line);
      display: none;
    }
    mobile-nav.open .primary-nav {
      display: block;
    }
    .primary-nav ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: var(--space-2) var(--space-6) var(--space-4);
    }
    .nav-link {
      display: block;
      padding: 0.75rem 0;
      border-bottom: var(--hairline);
      border-radius: 0;
    }
    .nav-link.active {
      border-bottom: var(--hairline);
      color: var(--red-hover);
    }
    .nav-social {
      margin-left: 0;
      padding-left: 0;
      padding-top: var(--space-3);
      border-left: none;
      gap: var(--space-2);
    }
    /* animate the toggle into an X when open */
    mobile-nav.open .nav-toggle-bars {
      background: transparent;
    }
    mobile-nav.open .nav-toggle-bars::before {
      top: 0;
      transform: rotate(45deg);
    }
    mobile-nav.open .nav-toggle-bars::after {
      top: 0;
      transform: rotate(-45deg);
    }
  }
</style>
